import numpy as np
import random
from environment_buildup import UAVEnvironment2D
from path_evaluator import PathEvaluator
import matplotlib.pyplot as plt

class DSACOPlanner:
    def __init__(self, env, evaluator, num_ants=40, num_iterations=100, 
                 alpha=1.0, beta=2.0, rho=0.2, Q=100, num_segments=7):
        self.env = env
        self.evaluator = evaluator
        self.num_ants = num_ants
        self.num_iterations = num_iterations
        self.alpha = alpha
        self.beta = beta
        self.rho = rho
        self.Q = Q
        self.num_segments = num_segments
        
        #==========论文改进参数========
        self.q0_initial = 0.9     # 论文中推荐的确定性选择初始概率
        self.tau_max = 10.0       # 论文中的最大信息素浓度界限
        self.tau_min = 0.1        # 论文中的最小信息素浓度界限
        self.p_weight = 1.0       # 论文中的全局最优适应度权重参数 p
        #============================

        self.x_coords = np.linspace(self.env.start_point[0], self.env.end_point[0], self.num_segments + 1)
        self.num_candidates = 30  
        self.y_candidates = np.linspace(self.env.y_bounds[0], self.env.y_bounds[1], self.num_candidates)
        
        self.pheromone = []
        self.pheromone.append(np.ones(self.num_candidates))
        for i in range(self.num_segments - 2):
            self.pheromone.append(np.ones((self.num_candidates, self.num_candidates)))
        self.pheromone.append(np.ones(self.num_candidates))
        
        self.global_best_path = None
        self.global_best_fitness = float('inf')

    def run(self):
        """算法主循环"""
        print("开始运行DSASO路径规划...")
        
        for idx in range(self.num_iterations):
            all_paths = []
            all_fitness = []
            
            for ant in range(self.num_ants):
                # 【已修复】：传入当前迭代步数 idx
                path = self._construct_path(idx) 
                fitness = self.evaluator.calculate_fitness(path)
                
                all_paths.append(path)
                all_fitness.append(fitness)
                
                if fitness < self.global_best_fitness:
                    self.global_best_fitness = fitness
                    self.global_best_path = path
            
            # 【已修复】：传入当前迭代步数 idx
            self._update_pheromones(all_paths, all_fitness, idx) 
            
            if (idx + 1) % 10 == 0 or idx == 0:
                print(f"迭代次数 [{idx+1}/{self.num_iterations}] -> 当前历史最佳适应度(Fitness): {self.global_best_fitness:.2f}")
                
        print("优化完成！")
        return self.global_best_path, self.global_best_fitness

    def _construct_path(self, current_iteration):
        """单只蚂蚁构建一条从起点到终点的路点路径"""
        path_idx = [] 
        
        K = self.num_iterations
        k0 = 0.7 * K
        if current_iteration < k0:
            q0 = ((K - current_iteration) / K) * self.q0_initial
        else:
            q0 = ((K - k0) / K) * self.q0_initial + (self.q0_initial / 2.0)

        # 1. 决定从起点到第1个控制点
        prob = np.copy(self.pheromone[0])
        for j in range(self.num_candidates):
            p_next = np.array([self.x_coords[1], self.y_candidates[j]])
            if self.env.is_point_in_obstacle(p_next):
                prob[j] *= 0.01
            dist = self.env.calculate_distance(p_next, self.env.end_point)
            heuristic = 1.0 / (dist + 1e-4)
            prob[j] = (prob[j] ** self.alpha) * (heuristic ** self.beta)
            
        # === 【已修复】：NumPy数值截断精度防御 ===
        q = random.random()
        if q <= q0:
            first_idx = np.argmax(prob) 
        else:
            total_prob = np.sum(prob)
            if total_prob > 0:
                prob /= total_prob
            else:
                prob = np.ones_like(prob) / len(prob)
            prob /= np.sum(prob) # 二次强校验补齐 1.0
            first_idx = np.random.choice(self.num_candidates, p=prob) 
            
        path_idx.append(first_idx)
        
        # 2. 决定中间各列的选择
        for i in range(1, self.num_segments - 1):
            curr_y_idx = path_idx[-1]
            prob = np.copy(self.pheromone[i][curr_y_idx])
            p_curr = np.array([self.x_coords[i], self.y_candidates[curr_y_idx]])
            
            for j in range(self.num_candidates):
                p_next = np.array([self.x_coords[i+1], self.y_candidates[j]])
                if self.env.is_segment_collision(p_curr, p_next, safe_margin=0.0):
                    prob[j] *= 0.001
                    
                dist_to_end = self.env.calculate_distance(p_next, self.env.end_point)
                dist_to_targets = [self.env.calculate_distance(p_next, t['center']) for t in self.env.target_areas]
                min_target_dist = min(dist_to_targets)
                heuristic = 1.0 / (dist_to_end + 0.3 * min_target_dist + 1e-4)
                
                prob[j] = (prob[j] ** self.alpha) * (heuristic ** self.beta)
                
            # === 【已修复】：NumPy数值截断精度防御 ===
            q = random.random()
            if q <= q0:
                next_idx = np.argmax(prob) 
            else:
                total_prob = np.sum(prob)
                if total_prob > 0:
                    prob /= total_prob
                else:
                    prob = np.ones_like(prob) / len(prob)
                prob /= np.sum(prob) # 二次强校验补齐 1.0
                next_idx = np.random.choice(self.num_candidates, p=prob)
                
            path_idx.append(next_idx)
            
        # 3. 将索引组装为真正的全节点坐标路径
        actual_path = [self.env.start_point]
        for i, y_idx in enumerate(path_idx):
            actual_path.append(np.array([self.x_coords[i+1], self.y_candidates[y_idx]]))
        actual_path.append(self.env.end_point)
        
        return np.array(actual_path)

    def _update_pheromones(self, all_paths, all_fitness, current_iteration):
        """融合了论文策略2：动态调整的信息素更新与 MAX-MIN 边界"""
        best_idx_now = np.argmin(all_fitness)
        best_path_now = all_paths[best_idx_now]
        fitness_now = all_fitness[best_idx_now]
        
        for i in range(len(self.pheromone)):
            self.pheromone[i] *= (1.0 - self.rho)
            
        if current_iteration > 0 and current_iteration % 10 == 0:  
            self.p_weight *= 0.9 

        denominator = (1.0 - self.p_weight) * fitness_now + self.p_weight * self.global_best_fitness
        delta_p = self.Q / (denominator + 1e-4)
        
        y_indices = []
        for p in best_path_now[1:-1]:
            idx = np.argmin(np.abs(self.y_candidates - p[1]))
            y_indices.append(idx)
            
        self.pheromone[0][y_indices[0]] += delta_p
        for i in range(len(y_indices) - 1):
            self.pheromone[i+1][y_indices[i], y_indices[i+1]] += delta_p
        self.pheromone[-1][y_indices[-1]] += delta_p

        for i in range(len(self.pheromone)):
            self.pheromone[i] = np.clip(self.pheromone[i], self.tau_min, self.tau_max)


# ================== 执行与可视化验证 ==================
if __name__ == "__main__":
    # 1. 实例化环境和评估器
    env = UAVEnvironment2D()
    evaluator = PathEvaluator()
    
    # 2. 实例化蚁群算法
    # 连续空间分段设为 6-9 段效果最佳，保证能弯曲绕开障碍物去巡检点，同时转弯角度不会太细碎
    planner = DSACOPlanner(
        env=env,
        evaluator=evaluator,
        num_ants=100,          # 每次迭代派出的蚂蚁数量
        num_iterations=300,    # 迭代次数
        alpha=1.0,            # 信息素权重
        beta=3.0,             # 启发性距离权重（稍微调高有利于加速避障收敛）
        rho=0.3,              # 挥发率
        Q=500,                # 信息素增量基数
        num_segments=8        # 中间划分的路段节点数
    )
    
    # 3. 运行算法获取最佳路径
    best_path, best_score = planner.run()
    
    print("\n================ 规划结果汇总 ================")
    print(f"最终得分: {best_score:.4f}")
   
    
    # 4. 画图展示结果
    fig, ax = plt.subplots(figsize=(10, 10))
    env.draw_environment(ax=ax)
    
    # 绘制规划出的最优路径
    best_path = np.array(best_path)
    ax.plot(best_path[:, 0], best_path[:, 1], color='#e65100', linewidth=3, 
            marker='o', markersize=6, label='DSASO Optimized Path', zorder=5)
    
    # 将路点序号标出来方便检查转弯
    for k, pt in enumerate(best_path):
        ax.text(pt[0]+1, pt[1]+1, f"P{k}", color='black', fontsize=9)
        
    ax.legend(loc='upper right')
    plt.show()